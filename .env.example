# Sequence WaaS credentials — rotate these if compromised
EXPO_PUBLIC_PROJECT_ACCESS_KEY=your_project_access_key
EXPO_PUBLIC_WAAS_CONFIG_KEY=your_waas_config_key_base64

# Google OAuth client IDs (public by OAuth2 design, but keep per-environment)
EXPO_PUBLIC_WEB_GOOGLE_CLIENT_ID=your_web_google_client_id
EXPO_PUBLIC_IOS_GOOGLE_CLIENT_ID=your_ios_google_client_id
EXPO_PUBLIC_IOS_GOOGLE_REDIRECT_URI=your_ios_google_redirect_uri

# Game session API (server-side reward validation)
EXPO_PUBLIC_GAME_SESSION_API_URL=https://api.tapnation.example.com

# Blockchain RPC
EXPO_PUBLIC_AVAX_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
